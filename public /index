<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Luxury Restaurant</title>
</head>
<body class="bg-gray-100">

<!-- NAVBAR -->
<nav class="bg-black text-white p-4 flex justify-between">
  <h1 class="text-xl font-bold">🍽 Royal Bites</h1>
  <div class="space-x-4">
    <a href="#menu">Menu</a>
    <a href="#book">Book Table</a>
    <a href="#order">Order</a>
  </div>
</nav>

<!-- HERO -->
<section class="h-96 flex flex-col justify-center items-center bg-cover bg-center text-white"
style="background-image:url('https://images.unsplash.com/photo-1504674900247-0877df9cc836')">
  <h2 class="text-4xl font-bold">Delicious Food, Premium Experience</h2>
  <button class="mt-4 bg-red-600 px-6 py-2 rounded">Order Now</button>
</section>

<!-- MENU -->
<section id="menu" class="p-10">
  <h2 class="text-3xl font-bold mb-6">Menu</h2>
  <div id="menuList" class="grid grid-cols-1 md:grid-cols-3 gap-6"></div>
</section>

<!-- BOOK TABLE -->
<section id="book" class="p-10 bg-white">
  <h2 class="text-3xl font-bold mb-4">Book a Table</h2>
  <input id="name" placeholder="Name" class="border p-2 m-2" />
  <input id="date" type="date" class="border p-2 m-2" />
  <div class="grid grid-cols-4 gap-2 mt-4" id="tables"></div>
  <button onclick="bookTable()" class="bg-green-600 text-white px-4 py-2 mt-4">Confirm Booking</button>
</section>

<!-- ORDER -->
<section id="order" class="p-10">
  <h2 class="text-3xl font-bold mb-4">Order Food</h2>
  <div id="cart" class="mb-4"></div>
  <button onclick="placeOrder()" class="bg-blue-600 text-white px-4 py-2">Place Order</button>
</section>

<script src="script.js"></script>
</body>
</html>
